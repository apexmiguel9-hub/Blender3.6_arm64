+
+/** \file ghost/intern/GHOST_SystemAndroid.cpp
+ *  \ingroup GHOST
+ */
+
+#include "GHOST_SystemAndroid.h"
+#include "GHOST_Event.h"
+#include "GHOST_EventButton.h"
+#include "GHOST_EventCursor.h"
+#include "GHOST_EventKey.h"
+#include "GHOST_EventWheel.h"
+
+#include <EGL/egl.h>
+#include <android/native_window.h>
+#include <android/native_window_jni.h>
+
+GHOST_SystemAndroid::GHOST_SystemAndroid()
+    : m_window(NULL)
+{
+}
+
+GHOST_SystemAndroid::~GHOST_SystemAndroid()
+{
+}
+
+bool GHOST_SystemAndroid::processEvents(bool waitForEvent)
+{
+	return false;
+}
+
+int GHOST_SystemAndroid::toggleConsole(int action)
+{
+	return 0;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::getCursorPosition(
+        GHOST_TInt32 &x, GHOST_TInt32 &y) const
+{
+	x = 0; y = 0;
+	return GHOST_kSuccess;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::setCursorPosition(GHOST_TInt32 x, GHOST_TInt32 y)
+{
+	return GHOST_kSuccess;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::getCursorGrabState(bool &grab, bool &hide)
+{
+	grab = false;
+	hide = true;
+	return GHOST_kSuccess;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::setCursorGrabState(bool grab, bool hide)
+{
+	return GHOST_kSuccess;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::getCursorVisibility(bool &visible)
+{
+	visible = true;
+	return GHOST_kSuccess;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::setCursorVisibility(bool visible)
+{
+	return GHOST_kSuccess;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::getModifierKeys(
+        GHOST_ModifierKeys &keys) const
+{
+	keys.clear();
+	return GHOST_kSuccess;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::getButtons(GHOST_Buttons &buttons) const
+{
+	buttons.clear();
+	return GHOST_kSuccess;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::setCursorShape(
+        GHOST_TStandardCursor cursorShape)
+{
+	return GHOST_kSuccess;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::hasCursorShape(
+        GHOST_TStandardCursor cursorShape)
+{
+	return GHOST_kFailure;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::setCustomCursorShape(
+        GHOST_TUns8 *bitmap, GHOST_TUns8 *mask,
+        int sizex, int sizey, int hotX, int hotY,
+        int fgColor, int bgColor)
+{
+	return GHOST_kSuccess;
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::getWindowBounds(
+        const GHOST_IWindow *window,
+        GHOST_Rect &bounds) const
+{
+	return getClientBounds(window, bounds);
+}
+
+GHOST_TSuccess GHOST_SystemAndroid::getClientBounds(
+        const GHOST_IWindow *window,
+        GHOST_Rect &bounds) const
+{
+	if (m_window) {
+		bounds = m_window->getClientBounds();
+		return GHOST_kSuccess;
+	}
+	return GHOST_kFailure;
+}
+
+/* C API for Android JNI */
+#include "GHOST_C-api.h"
+
+static GHOST_SystemAndroid *g_system = NULL;
+
+extern "C" int GHOST_Android_init(JNIEnv *env, jobject surface, int w, int h)
+{
+	if (g_system)
+		return 0;
+
+	g_system = new GHOST_SystemAndroid();
+
+	ANativeWindow *nativeWindow = ANativeWindow_fromSurface(env, surface);
+	if (!nativeWindow)
+		return -1;
+
+	GHOST_WindowAndroid *window = new GHOST_WindowAndroid(
+	        nativeWindow, w, h, false, false, 0);
+
+	if (!window->getValid()) {
+		delete window;
+		delete g_system;
+		g_system = NULL;
+		return -2;
+	}
+
+	g_system->m_window = window;
+	return 0;
+}
+
+extern "C" int GHOST_Android_setSurface(JNIEnv *env, jobject surface, int w, int h)
+{
+	if (!g_system || !g_system->m_window)
+		return -1;
+
+	ANativeWindow *nativeWindow = ANativeWindow_fromSurface(env, surface);
+	if (!nativeWindow)
+		return -1;
+
+	g_system->m_window->setNativeWindow(nativeWindow, w, h);
+	return 0;
+}
+
+extern "C" int GHOST_Android_touchEvent(int action, float x, float y)
+{
+	if (!g_system)
+		return -1;
+	return 0;
+}
+
+extern "C" int GHOST_Android_keyEvent(int down, int keyCode, int metaState)
+{
+	if (!g_system)
+		return -1;
+	return 0;
+}
